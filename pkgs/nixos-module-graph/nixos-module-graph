def colorize(text, *codes):
    return "".join(codes) + text + RESET


# ── Helpers ─────────────────────────────────────────────────

def fatal(msg):
    print(f"{RED}error:{RESET} {msg}", file=sys.stderr)
    sys.exit(1)


def find_cmd(name):
    cmd = shutil.which(name)
    if not cmd:
        fatal(f"'{name}' not found — please install it")
    return cmd


def find_self_dir():
    return os.path.dirname(os.path.abspath(__file__))


def find_share():
    d = find_self_dir()
    for candidate in (
        os.path.join(d, "..", "share", "nixos-module-graph"),
        os.path.join(d, "..", "..", "share", "nixos-module-graph"),
        os.path.join(d, "..", "lib", "nixos-module-graph"),
        os.path.join(d, "..", "..", "lib", "nixos-module-graph"),
    ):
        if os.path.isdir(candidate):
            return candidate
    return d


def share_path(name):
    share = find_share()
    p = os.path.join(share, name)
    if not os.path.exists(p):
        p2 = os.path.join(find_self_dir(), name)
        if os.path.exists(p2):
            return p2
    if not os.path.exists(p):
        fatal(f"{name} not found in share dirs")
    return p


def nix_eval(expr, timeout=30):
    nix = find_cmd("nix")
    cmd = [nix, "eval", "--json", "--impure", "--expr", expr, "--no-warn-dirty"]
    try:
        r = subprocess.run(cmd, capture_output=True, text=True, timeout=timeout)
        if r.returncode != 0:
            return None, r.stderr.strip()
        return json.loads(r.stdout), None
    except subprocess.TimeoutExpired:
        return None, "evaluation timed out"
    except json.JSONDecodeError as e:
        return None, f"JSON decode: {e}"
    except Exception as e:
        return None, str(e)


# ── Module source classifier ────────────────────────────────

def classify_module(filepath):
    if "nix/store" in filepath and ("nixpkgs" in filepath or "nixos" in filepath):
        return "nixpkgs"
    if "/nixos/" in filepath and "/modules/" in filepath:
        return "nixpkgs"
    if filepath.startswith("/nix/store/"):
        return "store"
    if filepath.startswith("/etc/nixos") or filepath.startswith("/home/"):
        return "user"
    if filepath.startswith("flake:"):
        return "flake"
    if filepath in ("anonymous", "unknown", "?"):
        return "other"
    return "local"


def file_short(filepath, max_len=50):
    if len(filepath) <= max_len:
        return filepath
    m = re.search(r"/nix/store/[^/]+/(.*)", filepath)
    if m:
        short = m.group(1)
        if len(short) <= max_len:
            return short
        return "…" + short[-(max_len - 1):]
    return "…" + filepath[-(max_len - 1):]


# ── Pure-Python Nix module import extraction ────────────────
# Instead of evaluating Nix (which breaks on missing args),
# we parse .nix files with regex to extract imports = [ ... ].

IMPORT_RE = re.compile(
    r'imports\s*=\s*\[(.*?)\]',
    re.DOTALL | re.MULTILINE
)
PATH_RE = re.compile(
    r"""
    (?:\./)?[a-zA-Z0-9_./-]+\.nix
    |
    \./[a-zA-Z0-9_./-]+
    """,
    re.VERBOSE
)
STRING_PATH_RE = re.compile(r'"((?:\./)?[^"]*(?:\.nix)?)"')


def read_file_safe(path):
    try:
        with open(path, encoding="utf-8", errors="replace") as f:
            return f.read()
    except Exception:
        return None


def extract_imports_from_nix(filepath):
    """Extract imports list from a .nix file without evaluating it."""
    content = read_file_safe(filepath)
    if content is None:
        return []

    imports = []

    # Remove comments to avoid false matches
    content = remove_nix_comments(content)

    # Find imports = [ ... ]
    for m in IMPORT_RE.finditer(content):
        block = m.group(1)

        # Match path-like entries
        for pm in re.finditer(r'(\./[\w./-]+)', block):
            imports.append(pm.group(1))

        # Match string paths: "path" or "${path}"
        for pm in re.finditer(r'"((?:\./)?[^"]+)"', block):
            val = pm.group(1)
            if not val.startswith("${"):  # skip interpolated strings
                imports.append(val)

        # Match raw identifiers that look like paths
        for pm in re.finditer(r'\b(\./[\w./-]+)\b', block):
            val = pm.group(1)
            if val not in imports:
                imports.append(val)

    return list(dict.fromkeys(imports))  # dedup preserving order


def remove_nix_comments(content):
    """Remove Nix comments (single-line and multi-line)."""
    # Remove multi-line comments /* ... */
    content = re.sub(r'/\*.*?\*/', '', content, flags=re.DOTALL)
    # Remove single-line comments # ... and // ...
    lines = content.split('\n')
    cleaned = []
    for line in lines:
        # Simple comment removal
        idx = -1
        for marker in ['#', '//']:
            pos = line.find(marker)
            if pos != -1:
                # Check it's not inside a string
                quote_count = line[:pos].count('"')
                if quote_count % 2 == 0:  # not inside string
                    idx = pos if idx == -1 else min(idx, pos)
        if idx != -1:
            line = line[:idx]
        cleaned.append(line)
    return '\n'.join(cleaned)


def resolve_import(base_dir, imp_path):
    """Resolve an import path relative to the containing file's directory."""
    imp_path = imp_path.strip().strip('"').strip("'")
    if imp_path.startswith("./"):
        return os.path.normpath(os.path.join(base_dir, imp_path))
    if imp_path.startswith("/"):
        return imp_path
    # Might be a store path or nixpkgs reference
    return None


def walk_imports(filepath, max_depth=100, visited=None, depth=0):
    """Walk the import tree of a NixOS module file recursively (pure Python)."""
    if visited is None:
        visited = set()

    filepath = os.path.abspath(filepath)
    norm = os.path.normpath(filepath)

    if norm in visited:
        return {"file": norm, "options": [], "imports": [], "cycle": True, "error": None}
    if depth > max_depth:
        return {"file": norm, "options": [], "imports": [], "cycle": False, "error": "max-depth"}

    visited.add(norm)

    # Handle directories: import dir resolves to dir/default.nix
    if os.path.isdir(norm):
        default_nix = os.path.join(norm, "default.nix")
        if os.path.isfile(default_nix):
            norm = default_nix
        else:
            norm = default_nix

    # Check it's a file
    if not os.path.isfile(norm):
        return {"file": norm, "options": [], "imports": [], "cycle": False, "error": "not-found"}

    # Extract imports
    raw_imports = extract_imports_from_nix(norm)
    base_dir = os.path.dirname(norm)

    resolved = []
    for imp in raw_imports:
        resolved_path = resolve_import(base_dir, imp)
        if resolved_path and os.path.exists(resolved_path):
            resolved.append(resolved_path)
        elif resolved_path:
            resolved.append(resolved_path)

    children = []
    for r in resolved:
        try:
            child = walk_imports(r, max_depth, visited.copy(), depth + 1)
            children.append(child)
        except Exception:
            children.append({"file": r, "options": [], "imports": [], "cycle": False, "error": "walk-error"})

    return {
        "file": norm,
        "options": [],
        "imports": children,
        "cycle": False,
        "error": None,
    }


# ── Flake URI and parsing ───────────────────────────────────

def parse_flake_uri(uri):
    uri = os.path.expanduser(uri)
    if "#" in uri:
        path, host = uri.rsplit("#", 1)
        path = path or "."
    else:
        path = uri.rstrip("/") or "."
        host = None
    return path, host


def parse_flake_nix_for_modules(flake_dir):
    """Parse flake.nix to extract hostname -> module paths mappings."""
    flake_dir = os.path.expanduser(flake_dir)
    flake_nix = os.path.join(flake_dir, "flake.nix")
    if not os.path.isfile(flake_nix):
        return {}

    with open(flake_nix) as f:
        content = f.read()

    hosts = {}
    config_block = None
    cm = re.search(r'nixosConfigurations\s*=', content)
    if cm:
        brace_start = content.find('{', cm.end())
        if brace_start != -1:
            depth = 1; i = brace_start + 1
            while i < len(content) and depth > 0:
                if content[i] == '{': depth += 1
                elif content[i] == '}': depth -= 1
                i += 1
            if depth == 0:
                config_block = content[brace_start + 1:i - 1]

    if config_block:
        for m in re.finditer(r'^\s*(\w+)\s*=\s*(?:\w+(?:\.\w+)*\.)?nixosSystem\s*\{', config_block, re.MULTILINE):
            hostname = m.group(1)
            start = m.end()
            chunk = config_block[start:start + 3000]
            mod_m = re.search(r'modules\s*=\s*\[', chunk)
            if not mod_m: continue
            mod_start = start + mod_m.end()
            paths = _extract_module_paths(config_block, mod_start)
            if paths:
                hosts[hostname] = paths

    return hosts


def _extract_module_paths(content, start_idx):
    depth = 1; i = start_idx; paths = []
    while i < len(content) and depth > 0:
        c = content[i]
        if c == '[': depth += 1
        elif c == ']': depth -= 1
        elif depth == 1 and c == '.' and i + 1 < len(content) and content[i + 1] in ('/', '"', "'"):
            si = i
            while i < len(content) and content[i] not in (' ', '\t', '\n', ']', ';', ')', ',', '}'):
                i += 1
            raw = content[si:i].strip()
            if raw: paths.append(raw)
            continue
        elif depth == 1 and c in ('"', "'"):
            quote = c; si = i; i += 1
            while i < len(content) and content[i] != quote:
                if content[i] == '\\': i += 1
                i += 1
            raw = content[si:i + 1].strip()
            if raw and not raw.startswith('"${'):
                paths.append(raw.strip('"\''))
            i += 1
            continue
        i += 1
    return paths


def try_find_config_in_flake(flake_dir):
    flake_dir = os.path.abspath(os.path.expanduser(flake_dir))
    candidates = [
        os.path.join(flake_dir, "configuration.nix"),
        os.path.join(flake_dir, "default.nix"),
        os.path.join(flake_dir, "config.nix"),
        os.path.join(flake_dir, "hosts", "default.nix"),
        os.path.join(flake_dir, "hosts", "configuration.nix"),
        os.path.join(flake_dir, "nixos", "configuration.nix"),
    ]
    for c in candidates:
        if os.path.isfile(c):
            return c
    nix_files = sorted(os.path.join(flake_dir, f) for f in os.listdir(flake_dir) if f.endswith(".nix"))
    if nix_files:
        return nix_files[0]
    return None


def flake_options(flake_uri, timeout=60):
    flake_path, host = parse_flake_uri(flake_uri)
    if host is None:
        return None, "no hostname specified (use .#hostname)"
    hosts_found = parse_flake_nix_for_modules(flake_path)
    if not hosts_found:
        return None, f"no nixosConfigurations found in {flake_path}/flake.nix"
    if host not in hosts_found and hosts_found:
        host = list(hosts_found.keys())[0]
    expr = (
        "let\n"
        '  flake = builtins.getFlake "{}";\n'
        "  cfg = flake.nixosConfigurations.{};\n"
        "  optNames = builtins.attrNames cfg.options;\n"
        "  take = n: l: if n >= builtins.length l then l else builtins.genList (i: builtins.elemAt l i) n;\n"
        "in\n"
        "  builtins.map (name: {{\n"
        "    option = name;\n"
        '    declarations = cfg.options.${{name}}.declarations or [];\n'
        "    type = if cfg.options.${{name}} ? type then cfg.options.${{name}}.type.description or \"unknown\" else null;\n"
        '    description = cfg.options.${{name}}.description or "";\n'
        "  }})\n"
        "  (take 2000 optNames)\n"
    ).format(flake_path, host)
    data, err = nix_eval(expr, timeout)
    if err:
        return None, err
    return data, None


# ── Graph extraction ────────────────────────────────────────

def extract_graph(config_path, max_depth=100):
    config_path = os.path.abspath(config_path)
    if not os.path.exists(config_path):
        fatal(f"config file not found: {config_path}")
    return walk_imports(config_path, max_depth)


def analyze_option(config_path, option_name):
    opath = share_path("option.nix")
    config_path = os.path.abspath(config_path)
    nix = find_cmd("nix-instantiate")
    cmd = [nix, "--eval", "--strict", "--json", opath,
           "--argstr", "configFile", config_path,
           "--argstr", "optionName", option_name]
    try:
        r = subprocess.run(cmd, capture_output=True, text=True, timeout=60)
        if r.returncode != 0:
            fatal(f"option analysis failed: {r.stderr.strip()}")
        return json.loads(r.stdout)
    except subprocess.TimeoutExpired:
        fatal("option analysis timed out")
    except json.JSONDecodeError as e:
        fatal(f"JSON decode: {e}")
    except Exception as e:
        fatal(str(e))


def count_imports(node, seen=None):
    if seen is None:
        seen = set()
    f = node.get("file", "")
    if f in seen or node.get("cycle"):
        return 0
    seen.add(f)
    return 1 + sum(count_imports(c, seen) for c in node.get("imports", []))


def collect_nodes_edges(node, nodes=None, edges=None, parent=None):
    if nodes is None:
        nodes = {}
    if edges is None:
        edges = []
    f = node.get("file", "unknown")
    if f not in nodes:
        nodes[f] = {
            "file": f,
            "options": node.get("options", []),
            "cycle": node.get("cycle", False),
            "error": node.get("error"),
            "depth": 0,
        }
    if parent and parent != f:
        edges.append({"source": parent, "target": f})
    for child in node.get("imports", []):
        collect_nodes_edges(child, nodes, edges, f)
    return nodes, edges


def build_graph_from_flake_options(options_data):
    nodes = {}
    for item in options_data:
        for decl in item.get("declarations", []):
            if decl not in nodes:
                nodes[decl] = {"file": decl, "options": [], "cycle": False, "error": None}
            nodes[decl]["options"].append(item["option"])
    return nodes, []


# ── Beautiful TUI output ────────────────────────────────────

def format_tui(node, prefix="", is_last=True, depth=0, seen=None):
    if seen is None:
        seen = set()
    lines = []
    f = node.get("file", "?")
    kind = classify_module(f)
    short = file_short(f)
    klass = node.get("cycle", False)
    err = node.get("error")

    if klass:
        label = colorize(f" ⃤ {short}", BOLD, RED)
        badge = colorize(" CYCLE ", RED, BOLD)
    elif err:
        label = colorize(f" {short}", YELLOW)
        badge = colorize(f" {err} ", YELLOW, BOLD)
    else:
        c = {"nixpkgs": GREEN, "store": MAGENTA, "user": CYAN, "local": BLUE, "flake": YELLOW, "other": DIM}.get(kind, DIM)
        label = colorize(f" {short}", c)
        badge = ""

    src_badge = {
        "nixpkgs": colorize(" nixpkgs ", GREEN + DIM),
        "store": colorize(" store ", MAGENTA + DIM),
        "user": colorize(" local ", CYAN + DIM),
        "local": colorize(" local ", BLUE + DIM),
        "flake": colorize(" flake ", YELLOW + DIM),
        "other": "",
    }.get(kind, "")

    if depth == 0:
        lines.append(f"{colorize('·', BOLD)}{label}  {badge}{src_badge}")
    else:
        branch = "└──" if is_last else "├──"
        conn = f"{DIM}{prefix}{branch}{RESET}"
        rest = "    " if is_last else "│   "
        np = prefix + rest
        lines.append(f"{conn}{label} {badge}{src_badge}")
        if kind in ("nixpkgs",):
            lines.append(f"{DIM}{np}└── from: NixOS module system{RESET}")
        elif kind in ("store",):
            lines.append(f"{DIM}{np}└── from: nix store{RESET}")
        elif kind in ("user", "local"):
            lines.append(f"{DIM}{np}└── from: user config{RESET}")

    if klass:
        pass
    elif f in seen:
        lines.append(f"{DIM}{'    ' if is_last else '│   '}{prefix}└── ... (already shown){RESET}")
    else:
        seen.add(f)
        children = node.get("imports", [])
        for i, child in enumerate(children):
            is_last_child = i == len(children) - 1
            np2 = prefix + ("    " if is_last else "│   ")
            child_lines = format_tui(child, np2, is_last_child, depth + 1, seen)
            lines.extend(child_lines)
    return lines


def format_summary(graph, flake_info=None, option_info=None):
    lines = []
    lines.append("")
    lines.append(colorize("╭──────────────────────────────────────────────╮", BOLD, CYAN))
    lines.append(colorize(f"│         nixos-module-graph v{VERSION}          │", BOLD, CYAN))
    lines.append(colorize("╰──────────────────────────────────────────────╯", BOLD, CYAN))
    lines.append("")

    total = count_imports(graph)
    nodes, edges = collect_nodes_edges(graph)

    nixpkgs_ct = sum(1 for f in nodes if classify_module(f) == "nixpkgs")
    user_ct = sum(1 for f in nodes if classify_module(f) in ("user", "local"))
    store_ct = sum(1 for f in nodes if classify_module(f) == "store")
    cycle_ct = sum(1 for f, v in nodes.items() if v.get("cycle"))
    err_ct = sum(1 for f, v in nodes.items() if v.get("error"))

    lines.append(f"  {colorize('modules', BOLD)}          {total}")
    lines.append(f"  {colorize('files', BOLD)}            {len(nodes)}")
    if nixpkgs_ct: lines.append(f"   {colorize(f'{nixpkgs_ct} nixpkgs', GREEN)}")
    if user_ct: lines.append(f"   {colorize(f'{user_ct} local', BLUE)}")
    if store_ct: lines.append(f"   {colorize(f'{store_ct} store', MAGENTA)}")
    if cycle_ct: lines.append(f"   {colorize(f'{cycle_ct} cycles', RED)}")
    if err_ct: lines.append(f"   {colorize(f'{err_ct} errors', YELLOW)}")
    lines.append(f"  {colorize('edges', BOLD)}            {len(edges)}")
    if flake_info:
        lines.append(f"  {colorize('flake', BOLD)}           {colorize(flake_info, DIM)}")

    if option_info and "error" not in option_info:
        lines.append("")
        lines.append(f"  {colorize('option', BOLD)}          {option_info.get('option', '?')}")
        lines.append(f"  {colorize('declarations', BOLD)}   {len(option_info.get('declarations', []))} files")
        lines.append(f"  {colorize('definitions', BOLD)}    {len(option_info.get('definitions', []))}")
        if option_info.get("type"):
            lines.append(f"  {colorize('type', BOLD)}          {option_info['type']}")

    lines.append("")
    return lines


def format_flake_hosts(hosts):
    lines = []
    lines.append(colorize("  Hosts in flake.nix:", BOLD))
    for host, paths in hosts.items():
        lines.append(f"   {colorize(host, CYAN, BOLD)}")
        for p in paths:
            c = {"nixpkgs": GREEN, "local": BLUE, "user": CYAN, "store": MAGENTA, "flake": YELLOW}.get(classify_module(p), DIM)
            lines.append(f"    {colorize('└──', DIM)} {colorize(p, c)}")
    lines.append("")
    return lines


def format_option_details(option_info):
    if not option_info or "error" in option_info:
        return [colorize("  option not found", RED)]
    lines = []
    lines.append(colorize("╭── Option analysis ───────────────────────╮", BOLD, CYAN))
    lines.append(colorize(f"│  {option_info.get('option', '?'):<48}│", BOLD))
    lines.append(colorize("╰──────────────────────────────────────────╯", BOLD, CYAN))
    lines.append("")
    lines.append(f"  {colorize('type', BOLD)}         {option_info.get('type', '?')}")
    lines.append(f"  {colorize('default', BOLD)}      {option_info.get('default', 'null')}")
    if option_info.get("description"):
        lines.append(f"  {colorize('description', BOLD)}  {option_info['description'][:80]}")
    lines.append("")
    lines.append(f"  {colorize('Declarations', BOLD, GREEN)} ({len(option_info.get('declarations', []))} files):")
    for decl in option_info.get("declarations", [])[:15]:
        c = {"nixpkgs": GREEN, "local": BLUE, "user": CYAN, "store": MAGENTA}.get(classify_module(decl), DIM)
        lines.append(f"    {colorize('•', c)} {colorize(file_short(decl, 70), c)}")
    if len(option_info.get("declarations", [])) > 15:
        lines.append(f"    {DIM}… and {len(option_info['declarations']) - 15} more{RESET}")
    lines.append("")
    return lines


# ── Export formats ──────────────────────────────────────────

def format_text(node, prefix="", is_last=True, depth=0, seen=None):
    if seen is None:
        seen = set()
    lines = []
    f = node.get("file", "?")
    marker = ""
    if node.get("cycle"): marker = " [CYCLE]"
    if node.get("error"): marker = f" [{node['error']}]"
    if depth == 0:
        lines.append(f"· {f}{marker}")
    else:
        connector = "└── " if is_last else "├── "
        lines.append(f"{prefix}{connector}{f}{marker}")
    if node.get("cycle"): pass
    elif f in seen:
        lines.append(f"{prefix}    └── ... (already shown)")
    else:
        seen.add(f)
        children = node.get("imports", [])
        for i, child in enumerate(children):
            is_last_child = i == len(children) - 1
            new_prefix = prefix + ("    " if is_last else "│   ")
            child_lines = format_text(child, new_prefix, is_last_child, depth + 1, seen)
            lines.extend(child_lines)
    return lines


def export_dot(nodes, edges):
    lines = ["digraph NixOSModules {"]
    lines.append('  rankdir=LR;')
    lines.append('  node [shape=box, style=rounded, fontname="monospace", fontsize=10];')
    lines.append('  edge [color="#666666", arrowhead=open];')
    for f, info in nodes.items():
        label = os.path.basename(f) if f != "root" else f
        opts = info.get("options", [])
        attrs = []
        if info.get("cycle"): attrs.append("color=red, penwidth=2")
        elif info.get("error"): attrs.append("color=orange, penwidth=2")
        elif opts: attrs.append('color="#2ea44f", penwidth=1.5')
        else: attrs.append('color="#888888"')
        escaped = f.replace('"', '\\"')
        lines.append(f'  "{escaped}" [label="{label}"{" " + ", ".join(attrs) if attrs else ""}];')
    for edge in edges:
        src = edge["source"].replace('"', '\\"')
        tgt = edge["target"].replace('"', '\\"')
        lines.append(f'  "{src}" -> "{tgt}";')
    lines.append("}")
    return "\n".join(lines)


def export_html(nodes, edges, option_info=None):
    template = share_path("static/index.html")
    with open(template) as f:
        html = f.read()
    nodes_list = [{
        "id": f, "file": f, "basename": os.path.basename(f),
        "options": info.get("options", []),
        "cycle": info.get("cycle", False),
        "error": info.get("error"),
    } for f, info in nodes.items()]
    edges_list = [{"source": e["source"], "target": e["target"]} for e in edges]
    html = html.replace("/*__GRAPH_DATA__*/", f"var graphData = {json.dumps({'nodes': nodes_list, 'edges': edges_list})};")
    html = html.replace("/*__OPTION_DATA__*/", f"var optionData = {json.dumps(option_info) if option_info else 'null'};")
    return html


def export_json(nodes, edges, option_info=None):
    result = {
        "metadata": {"tool": "nixos-module-graph", "version": VERSION, "author": AUTHOR},
        "nodes": [{"id": f, "file": f, "options": info.get("options", []), "cycle": info.get("cycle", False), "error": info.get("error")} for f, info in nodes.items()],
        "edges": [{"source": e["source"], "target": e["target"]} for e in edges],
    }
    if option_info: result["option"] = option_info
    return json.dumps(result, indent=2)


def write_output(graph, output_path, fmt, option_info=None):
    nodes, edges = collect_nodes_edges(graph)
    fn = {"dot": export_dot, "json": export_json, "html": export_html}[fmt]
    content = fn(nodes, edges, option_info)
    if output_path:
        with open(output_path, "w") as f:
            f.write(content)
        print(f"written: {output_path}")
    else:
        print(content)


def start_server(graph, port, option_info=None):
    nodes, edges = collect_nodes_edges(graph)
    html_content = export_html(nodes, edges, option_info)

    class Handler(http.server.BaseHTTPRequestHandler):
        def do_GET(self):
            if self.path == "/data":
                self.send_response(200)
                self.send_header("Content-Type", "application/json; charset=utf-8")
                self.end_headers()
                self.wfile.write(export_json(nodes, edges, option_info).encode("utf-8"))
            else:
                self.send_response(200)
                self.send_header("Content-Type", "text/html; charset=utf-8")
                self.end_headers()
                self.wfile.write(html_content.encode("utf-8"))
        def log_message(self, fmt, *args):
            sys.stderr.write(f"[{self.address_string()}] {fmt % args}\n")

    print(f"starting server at http://localhost:{port}")
    httpd = http.server.HTTPServer(("", port), Handler)
    try:
        httpd.serve_forever()
    except KeyboardInterrupt:
        print("\nshutting down")


# ── CLI ─────────────────────────────────────────────────────

def parse_args():
    parser = argparse.ArgumentParser(
        prog="nixos-module-graph",
        description="Analyse NixOS module import structure in beautiful TUI and graphs",
        epilog="Author: bitplugg <zxckillka.off@gmail.com>",
    )
    src = parser.add_mutually_exclusive_group(required=True)
    src.add_argument("--config", metavar="PATH", help="NixOS config file (configuration.nix)")
    src.add_argument("--flake", metavar="URI#NAME", help="flake URI + hostname, e.g. .#nixos")
    parser.add_argument("-o", "--output", metavar="FILE", help="output file (.html/.dot/.json)")
    parser.add_argument("--option", metavar="NAME", help="trace a specific option (e.g. services.nginx.enable)")
    parser.add_argument("--text", action="store_true", help="print plain ASCII tree")
    parser.add_argument("--serve", action="store_true", help="start d3.js web server")
    parser.add_argument("--port", type=int, default=8080, help="HTTP port (default: 8080)")
    parser.add_argument("--max-depth", type=int, default=100, help="max recursion depth")
    parser.add_argument("--version", action="version", version=f"%(prog)s {VERSION}")
    return parser.parse_args()


def main():
    args = parse_args()
    graph = None
    option_info = None
    flake_info = None

    if args.config:
        if not os.path.exists(args.config):
            fatal(f"config not found: {args.config}")
        print(f"{DIM}extracting from {args.config}...{RESET}", file=sys.stderr)
        graph = extract_graph(args.config, args.max_depth)
        if args.option:
            print(f"{DIM}analysing option '{args.option}'...{RESET}", file=sys.stderr)
            option_info = analyze_option(args.config, args.option)

    elif args.flake:
        flake_path, host = parse_flake_uri(args.flake)
        flake_dir = os.path.abspath(flake_path)
        if host:
            flake_info = f"{os.path.basename(flake_dir)}#{host}"
        else:
            flake_info = os.path.basename(flake_dir)

        print(f"{DIM}analysing flake: {flake_dir}{RESET}", file=sys.stderr)

        hosts_in_flake = parse_flake_nix_for_modules(flake_dir)
        if hosts_in_flake:
            if host is None:
                host = list(hosts_in_flake.keys())[0]
                print(f"{DIM}  → auto-detected host: {host}{RESET}", file=sys.stderr)
            elif host not in hosts_in_flake:
                print(f"{YELLOW}  ⚠ host '{host}' not found in flake.nix{RESET}", file=sys.stderr)

        # Strategy 1: walk imports from flake.nix entry points
        if host and host in hosts_in_flake and hosts_in_flake[host]:
            paths = hosts_in_flake[host]
            resolved = []
            for p in paths:
                p_clean = p.strip('"').strip("'")
                if p_clean.startswith("./"):
                    abspath = os.path.normpath(os.path.join(flake_dir, p_clean))
                    if os.path.exists(abspath):
                        resolved.append(abspath)
            if resolved:
                print(f"{DIM}  → module entry points:{RESET}", file=sys.stderr)
                for r in resolved:
                    c = {"nixpkgs": GREEN, "local": BLUE, "user": CYAN, "store": MAGENTA}.get(classify_module(r), DIM)
                    print(f"    {colorize('•', c)} {colorize(file_short(r, 60), c)}", file=sys.stderr)
                print(f"{DIM}  → walking imports...{RESET}", file=sys.stderr)
                graph = {"file": f"flake:{host}", "options": [], "imports": [], "cycle": False}
                for r in resolved:
                    sub = walk_imports(r, args.max_depth)
                    graph["imports"].append(sub)

        # Strategy 2: find config directly
        if graph is None:
            config_file = try_find_config_in_flake(flake_dir)
            if config_file:
                print(f"{DIM}  → detected config: {config_file}{RESET}", file=sys.stderr)
                graph = walk_imports(config_file, args.max_depth)

        # Strategy 3: option-based
        if graph is None and host:
            print(f"{DIM}  → using option-based analysis{RESET}", file=sys.stderr)
            options_data, err = flake_options(args.flake)
            if err:
                fatal(f"flake analysis: {err}")
            nodes, _ = build_graph_from_flake_options(options_data)
            graph = {"file": f"flake:{host}", "options": [], "imports": [], "cycle": False}
            print(f"{DIM}  → {len(options_data)} options, {len(nodes)} files{RESET}", file=sys.stderr)
            if args.option:
                for item in options_data:
                    if item["option"] == args.option:
                        option_info = item; break

        if graph is None:
            fatal(f"could not analyse flake at {flake_dir} — no config or nixosConfigurations found")

    # Output format
    fmt = None
    if args.output:
        ext = os.path.splitext(args.output)[1].lower()
        fmt = {".html": "html", ".htm": "html", ".dot": "dot", ".gv": "dot", ".json": "json"}.get(ext, "json")
    elif args.text:
        fmt = "text"
    elif args.serve:
        fmt = "html"

    # Render
    if fmt == "text":
        for line in format_text(graph):
            print(line)
    elif fmt:
        write_output(graph, args.output, fmt, option_info)
    else:
        for line in format_summary(graph, flake_info, option_info):
            print(line)
        if flake_info and not args.text:
            fpath, _ = parse_flake_uri(args.flake)
            hosts = parse_flake_nix_for_modules(os.path.abspath(fpath))
            if hosts:
                for line in format_flake_hosts(hosts):
                    print(line)
        for line in format_tui(graph):
            print(line)
        if option_info and "error" not in option_info:
            for line in format_option_details(option_info):
                print(line)

    if args.serve:
        start_server(graph, args.port, option_info)


if __name__ == "__main__":
    main()
