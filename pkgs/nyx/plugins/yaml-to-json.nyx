#!/usr/bin/env python3
# description: Convert YAML to JSON
# version: 0.1.0
# author: bitplugg
import sys, json
try:
    import yaml
    data = yaml.safe_load(sys.stdin)
    print(json.dumps(data, indent=2))
except ImportError:
    print("PyYAML not installed")
except Exception as e:
    print(f"error: {e}")
