#!/usr/bin/env python3
# description: Check DNS resolution
# version: 0.1.0
# author: bitplugg
import subprocess, sys
host = sys.argv[1] if len(sys.argv) > 1 else "google.com"
try:
    r = subprocess.run(["host", host], capture_output=True, text=True, timeout=5)
    print(r.stdout.strip() if r.returncode == 0 else r.stderr.strip())
except Exception as e:
    print(f"DNS check failed: {e}")
