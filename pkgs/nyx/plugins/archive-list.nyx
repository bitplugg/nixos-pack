#!/usr/bin/env bash
# description: List archive contents
# version: 0.1.0
# author: bitplugg
file="$1"
if [ -z "$file" ]; then echo "Usage: archive-list <file>"; exit 1; fi
case "$file" in
  *.tar.gz|*.tgz) tar tzf "$file" 2>/dev/null | head -30 ;;
  *.tar.xz) tar tJf "$file" 2>/dev/null | head -30 ;;
  *.zip) unzip -l "$file" 2>/dev/null | head -30 ;;
  *.rar) unrar l "$file" 2>/dev/null | head -30 ;;
  *) echo "unknown archive type" ;;
esac
