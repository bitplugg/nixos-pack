#!/usr/bin/env python3
# description: Simple countdown timer
# version: 0.1.0
# author: bitplugg
import time, sys
seconds = int(sys.argv[1]) if len(sys.argv) > 1 else 10
print(f"Timer for {seconds}s...")
for i in range(seconds, 0, -1):
    print(f"  {i}s", end="\r")
    time.sleep(1)
print("\nTime is up!")
