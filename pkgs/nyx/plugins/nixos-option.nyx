#!/usr/bin/env python3
# description: Query a NixOS option
# version: 0.1.0
# author: bitplugg
import subprocess, sys
opt = sys.argv[1] if len(sys.argv) > 1 else "system.stateVersion"
try:
    r = subprocess.run(["nixos-option", opt], capture_output=True, text=True, timeout=30)
    print(r.stdout.strip() if r.returncode == 0 else r.stderr.strip())
except FileNotFoundError:
    print("nixos-option not available")
