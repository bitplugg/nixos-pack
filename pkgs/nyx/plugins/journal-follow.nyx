#!/usr/bin/env python3
# description: Follow journal logs
# version: 0.1.0
# author: bitplugg
import subprocess, sys
unit = sys.argv[1] if len(sys.argv) > 1 else ""
try:
    cmd = ["journalctl", "-f", "-n", "10", "--no-hostname"]
    if unit: cmd.extend(["-u", unit])
    subprocess.run(cmd)
except KeyboardInterrupt:
    pass
