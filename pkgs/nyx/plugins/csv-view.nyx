#!/usr/bin/env python3
# description: View CSV file
# version: 0.1.0
# author: bitplugg
import csv, sys
file = sys.argv[1] if len(sys.argv) > 1 else "/dev/stdin"
try:
    with open(file) as f:
        reader = csv.reader(f)
        for i, row in enumerate(reader):
            if i >= 20: break
            print(" | ".join(row))
except Exception as e:
    print(f"error: {e}")
