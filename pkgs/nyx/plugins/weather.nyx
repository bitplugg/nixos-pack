#!/usr/bin/env python3
# description: Show weather (wttr.in)
# version: 0.1.0
# author: bitplugg
import subprocess, sys
loc = sys.argv[1] if len(sys.argv) > 1 else ""
url = f"https://wttr.in/{loc}?format=4" if loc else "https://wttr.in?format=4"
try:
    r = subprocess.run(["curl", "-s", url], capture_output=True, text=True, timeout=5)
    print(r.stdout.strip() or "weather unavailable")
except Exception as e:
    print(f"error: {e}")
