#!/usr/bin/env python3
# description: Show status of a systemd unit
# version: 0.1.0
# author: bitplugg
import subprocess, sys
unit = sys.argv[1] if len(sys.argv) > 1 else "systemd-journald"
try:
    r = subprocess.run(["systemctl", "status", unit, "--no-pager", "-l"], capture_output=True, text=True, timeout=5)
    lines = r.stdout.strip().split("\n")[:15]
    print("\n".join(lines))
except Exception as e:
    print(f"error: {e}")
