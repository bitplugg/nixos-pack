#!/usr/bin/env python3
# description: Trace route to a host
# version: 0.1.0
# author: bitplugg
import subprocess, sys
host = sys.argv[1] if len(sys.argv) > 1 else "google.com"
try:
    r = subprocess.run(["traceroute", "-n", "-q", "1", "-w", "2", host], capture_output=True, text=True, timeout=15)
    print(r.stdout.strip() if r.returncode == 0 else r.stderr.strip())
except FileNotFoundError:
    print("traceroute not installed")
except Exception as e:
    print(f"error: {e}")
