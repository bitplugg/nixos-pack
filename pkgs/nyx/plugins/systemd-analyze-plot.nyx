#!/usr/bin/env python3
# description: Generate boot plot SVG
# version: 0.1.0
# author: bitplugg
import subprocess, sys
out = sys.argv[1] if len(sys.argv) > 1 else "boot.svg"
try:
    r = subprocess.run(["systemd-analyze", "plot"], capture_output=True, text=True, timeout=10)
    with open(out, "w") as f:
        f.write(r.stdout)
    print(f"saved boot plot to {out}")
except Exception as e:
    print(f"error: {e}")
