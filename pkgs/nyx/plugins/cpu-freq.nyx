#!/usr/bin/env bash
# description: Show CPU frequency
# version: 0.1.0
# author: bitplugg
echo "CPU Frequencies:"
cat /sys/devices/system/cpu/cpu*/cpufreq/scaling_cur_freq 2>/dev/null | awk '{print \$1/1000 " MHz"}' | nl || echo 'no cpufreq'
echo "---"
cat /sys/devices/system/cpu/cpu*/cpufreq/scaling_governor 2>/dev/null | sort | uniq -c | awk '{print \$2, \$1}' || true
