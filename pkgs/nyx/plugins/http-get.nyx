#!/usr/bin/env python3
# description: Simple HTTP GET
# version: 0.1.0
# author: bitplugg
import subprocess, sys
url = sys.argv[1] if len(sys.argv) > 1 else "https://httpbin.org/get"
try:
    r = subprocess.run(["curl", "-s", "-i", url], capture_output=True, text=True, timeout=10)
    lines = r.stdout.split("\n")[:30]
    print("\n".join(lines))
except Exception as e:
    print(f"error: {e}")
