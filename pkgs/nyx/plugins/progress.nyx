#!/usr/bin/env python3
# description: Simple progress bar
# version: 0.1.0
# author: bitplugg
import time, sys
total = int(sys.argv[1]) if len(sys.argv) > 1 else 50
for i in range(total + 1):
    pct = i * 100 // total
    bar = "#" * i + "-" * (total - i)
    print(f"\r[{bar}] {pct}%", end="")
    time.sleep(0.05)
print()
