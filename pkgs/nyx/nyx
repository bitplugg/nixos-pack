#!/usr/bin/env python3
import os
import shutil
import subprocess
import sys

VERSION = "0.1.0"
AUTHOR = "bitplugg <zxckillka.off@gmail.com>"

BOLD = "\033[1m"
DIM = "\033[2m"
RED = "\033[31m"
GREEN = "\033[32m"
YELLOW = "\033[33m"
CYAN = "\033[36m"
RESET = "\033[0m"

BUILTIN = {
    "health": "nixos-health",
    "graph": "nixos-module-graph",
    "build": "nixos-build-tui",
    "diff-lock": "nix-diff-lock",
    "report": "system-report",
    "update": "nixos-flake-update",
    "switch-diff": "nixos-switch-diff",
    "clean": "nixos-clean",
    "log": "nixos-log",
    "top": "nixos-top",
    "brrt": "brrtfetch",
    "rkn": "rkn-block-checker",
}

ALIASES = {
    "h": "health",
    "g": "graph",
    "b": "build",
    "dl": "diff-lock",
    "r": "report",
    "u": "update",
    "sd": "switch-diff",
    "c": "clean",
    "l": "log",
    "t": "top",
}

SUBCOMMANDS = {}
for alias, cmd in BUILTIN.items():
    SUBCOMMANDS[alias] = ("builtin", cmd)
for alias, target in ALIASES.items():
    SUBCOMMANDS[alias] = ("alias", target)


def find_external_plugins():
    """Discover nyx-* commands in PATH."""
    path = os.environ.get("PATH", "")
    plugins = {}
    for d in path.split(":"):
        if not os.path.isdir(d):
            continue
        try:
            for f in os.listdir(d):
                if f.startswith("nyx-") and os.access(os.path.join(d, f), os.X_OK):
                    name = f[4:]
                    plugins[name] = os.path.join(d, f)
        except PermissionError:
            continue
    return plugins


def show_help(plugins):
    print(f"{BOLD}nyx{RESET} {DIM}v{VERSION}{RESET}  —  plugin-based NixOS toolkit")
    print()
    print(f"  {DIM}usage:{RESET} nyx <command> [args...]")
    print()

    all_cmds = sorted(set(list(SUBCOMMANDS.keys()) + list(plugins.keys())))

    print(f"  {BOLD}commands{RESET}")
    for name in all_cmds:
        if name in ALIASES:
            continue
        info = SUBCOMMANDS.get(name)
        alias_str = ""
        for a, t in sorted(ALIASES.items()):
            if t == name:
                alias_str += f" {DIM}({a}){RESET}"
        if info:
            print(f"    {GREEN}{name}{RESET}{alias_str}")
        elif name in plugins:
            plugin = plugins[name]
            desc = ""
            print(f"    {YELLOW}{name}{RESET}  {DIM}[plugin]{RESET}")
        else:
            print(f"    {name}")

    print()
    print(f"  {DIM}plugins:{RESET} {len(plugins)} external")
    print(f"  {DIM}nyx --help{RESET}  show this")
    print()


def main():
    plugins = find_external_plugins()

    if len(sys.argv) < 2:
        show_help(plugins)
        return

    cmd = sys.argv[1]
    args = sys.argv[2:]

    if cmd in ("--help", "-h", "help"):
        show_help(plugins)
        return

    if cmd in ("--version", "-v"):
        print(f"nyx {VERSION}")
        return

    info = SUBCOMMANDS.get(cmd)
    if info:
        kind, target = info
        if kind == "alias":
            target = BUILTIN.get(target, target)
            target_cmd = shutil.which(target)
            if not target_cmd:
                print(f"{RED}error:{RESET} '{target}' not found — install the corresponding package")
                sys.exit(1)
            os.execvp(target_cmd, [target_cmd] + args)
        elif kind == "builtin":
            target_cmd = shutil.which(target)
            if not target_cmd:
                print(f"{RED}error:{RESET} '{target}' not found — install nixos-pack overlay or the package")
                sys.exit(1)
            os.execvp(target_cmd, [target_cmd] + args)
    elif cmd in plugins:
        os.execvp(plugins[cmd], [plugins[cmd]] + args)
    else:
        print(f"{RED}unknown command:{RESET} {cmd}")
        print(f"  {DIM}run 'nyx --help' for available commands{RESET}")
        sys.exit(1)


if __name__ == "__main__":
    main()
