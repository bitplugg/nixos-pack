#!/usr/bin/env python3
import os
import shutil
import stat
import subprocess
import sys

VERSION = "0.1.0"

BOLD = "\033[1m"
DIM = "\033[2m"
RED = "\033[31m"
GREEN = "\033[32m"
YELLOW = "\033[33m"
CYAN = "\033[36m"
RESET = "\033[0m"

BUILTIN = {
    "health": "nixos-health",
    "graph": "nixos-module-graph",
    "build": "nixos-build-tui",
    "diff-lock": "nix-diff-lock",
    "report": "system-report",
    "update": "nixos-flake-update",
    "switch-diff": "nixos-switch-diff",
    "clean": "nixos-clean",
    "log": "nixos-log",
    "top": "nixos-top",
    "brrt": "brrtfetch",
    "rkn": "rkn-block-checker",
}

ALIASES = {
    "h": "health", "g": "graph", "b": "build",
    "dl": "diff-lock", "r": "report", "u": "update",
    "sd": "switch-diff", "c": "clean", "l": "log", "t": "top",
}

PLUGIN_DIRS = [
    os.path.expanduser("~/.config/nyx/plugins"),
    "/etc/nyx/plugins",
]


def find_plugins():
    plugins = {}
    for d in PLUGIN_DIRS:
        if not os.path.isdir(d):
            continue
        try:
            for f in sorted(os.listdir(d)):
                if not f.endswith(".nyx"):
                    continue
                path = os.path.join(d, f)
                name = f[:-4]
                meta = read_plugin_meta(path)
                plugins[name] = {"path": path, "meta": meta}
        except PermissionError:
            continue
    return plugins


def read_plugin_meta(path):
    meta = {"description": "", "version": "", "author": ""}
    try:
        with open(path, encoding="utf-8", errors="replace") as f:
            for line in f:
                line = line.strip()
                if line.startswith("# name:"):
                    pass
                elif line.startswith("# description:"):
                    meta["description"] = line[len("# description:"):].strip()
                elif line.startswith("# version:"):
                    meta["version"] = line[len("# version:"):].strip()
                elif line.startswith("# author:"):
                    meta["author"] = line[len("# author:"):].strip()
                elif meta["description"] or meta["version"] or meta["author"]:
                    if not line.startswith("#"):
                        break
    except Exception:
        pass
    return meta


def show_help(plugins):
    print(f"{BOLD}nyx{RESET} {DIM}v{VERSION}{RESET}  —  plugin-based NixOS toolkit")
    print()
    print(f"  {DIM}usage:{RESET} nyx <command> [args...]")
    print()

    cmds = {}
    for name in BUILTIN:
        cmds[name] = ("builtin", BUILTIN[name])
    for name, info in plugins.items():
        cmds[name] = ("plugin", info)

    print(f"  {BOLD}commands{RESET}")
    for name in sorted(cmds):
        kind, info = cmds[name]
        alias_str = ""
        for a, t in sorted(ALIASES.items()):
            if t == name:
                alias_str += f" {DIM}({a}){RESET}"
        if kind == "builtin":
            desc = f"  {DIM}→ {info}{RESET}"
            print(f"    {GREEN}{name}{RESET}{alias_str}{desc}")
        else:
            d = info["meta"]["description"]
            desc = f"  {DIM}{d}{RESET}" if d else ""
            print(f"    {YELLOW}{name}{RESET}{alias_str}{desc}")

    print()
    print(f"  {DIM}plugins:{RESET} {len(plugins)} loaded")
    print(f"  {DIM}nyx --help{RESET}  show this")
    print()


def run_nyx_file(path, args):
    if not os.access(path, os.X_OK):
        st = os.stat(path)
        os.chmod(path, st.st_mode | stat.S_IXUSR | stat.S_IXGRP | stat.S_IXOTH)
    os.execve(path, [path] + args, os.environ)


def main():
    plugins = find_plugins()

    if len(sys.argv) < 2:
        show_help(plugins)
        return

    cmd = sys.argv[1]
    args = sys.argv[2:]

    if cmd in ("--help", "-h", "help"):
        show_help(plugins)
        return
    if cmd in ("--version", "-v"):
        print(f"nyx {VERSION}")
        return

    if cmd in ALIASES:
        cmd = ALIASES[cmd]

    if cmd in BUILTIN:
        target = BUILTIN[cmd]
        target_cmd = shutil.which(target)
        if not target_cmd:
            print(f"{RED}error:{RESET} '{target}' not found — install the package or add it to PATH")
            sys.exit(1)
        os.execvp(target_cmd, [target_cmd] + args)

    if cmd in plugins:
        run_nyx_file(plugins[cmd]["path"], args)

    print(f"{RED}unknown command:{RESET} {cmd}")
    print(f"  {DIM}run 'nyx --help' for available commands{RESET}")
    sys.exit(1)


if __name__ == "__main__":
    main()
